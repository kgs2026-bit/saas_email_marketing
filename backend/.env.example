# Database
DATABASE_URL="postgresql://username:password@localhost:5432/email_saas_db?connection_limit=20"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-too"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="/api/auth/google/callback"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_PRO="price_..."

# Redis (Upstash)
REDIS_URL="redis://default:password@us-east-1-123.redis.upstash.io:6379"
REDIS_PASSWORD="your-upstash-password"

# App Settings
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"
API_URL="http://localhost:3001"

# Email (for sending password reset, etc.)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Encryption
ENCRYPTION_KEY="32-character-encryption-key-here"

# Tracking
TRACKING_DOMAIN="http://localhost:3001"
OPEN_TRACKING_ENABLED="true"
CLICK_TRACKING_ENABLED="true"
